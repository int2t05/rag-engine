# 复制为 .env 后填写。仅列出 backend Settings 读取的变量（extra 已 ignore）。

# --- 应用 ---
PROJECT_NAME=RAG Engine
DEBUG=false

# --- MySQL ---
MYSQL_SERVER=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=rag_engine

# --- JWT ---
SECRET_KEY=change-me-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- MinIO ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=documents

# --- 模型路由（评估与业务共用；说明见 docs/业务流程/RAG评估与配置说明.md）---
CHAT_PROVIDER=openai
EMBEDDINGS_PROVIDER=openai

# --- OpenAI 兼容（对话 CHAT_PROVIDER=openai）---
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4

# --- 嵌入 EMBEDDINGS_PROVIDER=openai（与对话同网关可只填上面；不同则填下面）---
OPENAI_EMBEDDINGS_MODEL=text-embedding-ada-002
# OPENAI_EMBEDDINGS_API_BASE=
# OPENAI_EMBEDDINGS_API_KEY=

# --- Ollama：对话 CHAT_PROVIDER=ollama；嵌入 EMBEDDINGS_PROVIDER=ollama ---
OLLAMA_API_BASE=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_EMBEDDINGS_MODEL=nomic-embed-text
# 嵌入与对话不在同一节点时填写
# OLLAMA_EMBEDDINGS_API_BASE=http://localhost:11435

# --- 向量库 ---
VECTOR_STORE_TYPE=chroma
CHROMA_DB_HOST=localhost
CHROMA_DB_PORT=8001
QDRANT_URL=http://localhost:6333
QDRANT_PREFER_GRPC=true

# --- 其它（Docker 等可选）---
TZ=Asia/Shanghai
